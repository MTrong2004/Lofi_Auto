# Sao chép file này thành ".env" rồi điền giá trị. File .env đã nằm trong .gitignore.

# ==== Provider ảnh ====
# Khả dụng: pollinations, aihorde, huggingface, cloudflare, sdlocal
# Máy KHÔNG có GPU (mặc định): pollinations,aihorde,sdlocal
# Máy CÓ GPU chạy SD local:    sdlocal,pollinations,aihorde
IMAGE_PROVIDER_ORDER=pollinations,aihorde,sdlocal

# AI Horde: đăng ký key miễn phí tại stablehorde.net để được ưu tiên hàng đợi
# AI_HORDE_API_KEY=

# Hugging Face: token miễn phí tại huggingface.co/settings/tokens
# HUGGINGFACE_TOKEN=
# HUGGINGFACE_MODEL=stabilityai/stable-diffusion-xl-base-1.0

# Cloudflare Workers AI: free ~10k neurons/ngày (dash.cloudflare.com -> Workers AI)
# CLOUDFLARE_ACCOUNT_ID=
# CLOUDFLARE_API_TOKEN=

# ==== LLM viết prompt ảnh theo bài nhạc ====
# Mặc định dùng text.pollinations.ai miễn phí, KHÔNG cần key.
# Có key riêng thì đổi cả 3 dòng (mọi API chuẩn OpenAI chat completions đều được):
# Groq:       https://api.groq.com/openai/v1/chat/completions | llama-3.3-70b-versatile
# OpenRouter: https://openrouter.ai/api/v1/chat/completions   | google/gemini-2.0-flash-001
# PROMPT_API_URL=https://text.pollinations.ai/openai
# PROMPT_API_KEY=
# PROMPT_API_MODEL=openai

# ==== Stable Diffusion local (máy GPU - vd RTX 3050 Ti 4GB) ====
# Cùng máy:  http://127.0.0.1:7860
# Khác máy (SD chạy trên máy GPU, pipeline chạy máy này): http://<IP-máy-GPU>:7860
SD_LOCAL_API_URL=http://127.0.0.1:7860

# Tên file checkpoint trong stable-diffusion-webui/models/Stable-diffusion/
# Đề xuất SD 1.5 anime fine-tune: meinamix, anythingV5, counterfeitV30
SD_LOCAL_CHECKPOINT=meinamix_v12Final.safetensors

# Thông số sinh ảnh (phù hợp 4GB VRAM; nếu OOM giảm còn 896x504)
SD_LOCAL_WIDTH=1024
SD_LOCAL_HEIGHT=576
SD_LOCAL_STEPS=28
SD_LOCAL_CFG_SCALE=6.5
SD_LOCAL_SAMPLER=DPM++ 2M Karras

# ==== API key tùy chọn ====
# POLLINATIONS_API_KEY=
# PEXELS_API_KEY=
