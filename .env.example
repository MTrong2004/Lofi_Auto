# Copy this file to .env and add private keys locally. Never commit .env.

# Pixabay Video API
PIXABAY_API_KEY=
EFFECT_SEARCH_CACHE_TTL=86400
EFFECT_MAX_DOWNLOAD_MB=30
EFFECT_API_TIMEOUT=20

# ===== LLM cho mọi tác vụ văn bản (prompt ảnh, hiệu ứng, chữ, caption, dịch) =====
# Provider CHÍNH — OpenAI-compatible. Mặc định trỏ Gemini (endpoint OpenAI-compat).
# Lấy key tại Google AI Studio. Có thể dùng biến GEMINI_API_KEY thay cho PROMPT_API_KEY.
PROMPT_API_URL=https://generativelanguage.googleapis.com/v1beta/openai/chat/completions
PROMPT_API_KEY=
GEMINI_API_KEY=
# Mặc định flash-lite: quota ngày cao nhất free-tier (~15 RPM, ~500 RPD) -> hợp automation.
# Muốn chất lượng cao hơn (nhưng ~20 RPD): gemini-3.5-flash / gemini-3-flash / gemini-2.5-flash.
PROMPT_API_MODEL=gemini-3.1-flash-lite
PROMPT_API_TIMEOUT=30

# Fallback: thiếu key/hết quota/lỗi -> tự đổi model rồi đổi provider (Pollinations miễn phí).
LLM_FALLBACK_ENABLED=true
PROMPT_API_FALLBACK_MODEL=gemini-2.5-flash
PROMPT_API_FALLBACK_URL=https://text.pollinations.ai/openai
PROMPT_API_FALLBACK_KEY=
PROMPT_API_FALLBACK_URL_MODEL=openai
# Model ID Gemini free-tier đã xác nhận trên dashboard: gemini-3.1-flash-lite (500 RPD),
# gemini-3.5-flash / gemini-3-flash / gemini-2.5-flash (20 RPD). Pro cần bật billing.
# Optional YouTube caption brand voice
# CAPTION_CHANNEL_PROFILE=Warm, calm lofi channel for focus, study and relaxation.

# AI effect recommendation
EFFECT_AI_ENABLED=1
EFFECT_AI_MAX_QUERIES=3
EFFECT_AI_MAX_RESULTS=6
